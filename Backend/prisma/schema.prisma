// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String   @id @default(cuid())
  walletAddress   String   @unique @map("wallet_address")
  profileData     Json?    @map("profile_data")
  reputationScore Int      @default(0) @map("reputation_score")
  trustScore      Int      @default(500) @map("trust_score")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Notification fields
  email            String? @unique
  pushSubscription Json?   @map("push_subscription")

  // Relations
  createdProjects      Project[]               @relation("ProjectCreator")
  contributions        Contribution[]
  reputationHistory    ReputationHistory[]
  notificationSettings NotificationSetting?
  notifications        Notification[]
  reputationActivities ReputationActivity[]    @relation("ReputationSubject")
  reputationActsActor  ReputationActivity[]    @relation("ReputationActor")
  reputationScoreModel ReputationScore?
  endorsementsGiven    ReputationEndorsement[] @relation("Endorser")
  endorsementsReceived ReputationEndorsement[] @relation("Endorsed")
  sybilProfile         SybilProfile?
  disputesFiled        ReputationDispute[]     @relation("Disputer")
  disputesAgainst      ReputationDispute[]     @relation("Disputed")

  @@map("users")
}

model Project {
  id           String        @id @default(cuid())
  contractId   String        @unique @map("contract_id")
  creatorId    String        @map("creator_id")
  creator      User          @relation("ProjectCreator", fields: [creatorId], references: [id])
  title        String
  description  String?
  category     String
  goal         BigInt
  currentFunds BigInt        @default(0) @map("current_funds")
  deadline     DateTime
  ipfsHash     String?       @map("ipfs_hash")
  status       ProjectStatus @default(ACTIVE)
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  // Relations
  contributions Contribution[]
  milestones    Milestone[]

  @@map("projects")
}

model Contribution {
  id              String   @id @default(cuid())
  transactionHash String   @unique @map("transaction_hash")
  investorId      String   @map("investor_id")
  investor        User     @relation(fields: [investorId], references: [id])
  projectId       String   @map("project_id")
  project         Project  @relation(fields: [projectId], references: [id])
  amount          BigInt
  timestamp       DateTime @default(now())
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("contributions")
}

model Milestone {
  id             String          @id @default(cuid())
  projectId      String          @map("project_id")
  project        Project         @relation(fields: [projectId], references: [id])
  title          String
  description    String?
  fundingAmount  BigInt          @map("funding_amount")
  status         MilestoneStatus @default(PENDING)
  completionDate DateTime?       @map("completion_date")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  @@map("milestones")
}

model ReputationHistory {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id])
  scoreChange Int      @map("score_change")
  reason      String
  timestamp   DateTime @default(now())
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("reputation_history")
}

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("categories")
}

enum ProjectStatus {
  ACTIVE
  COMPLETED
  CANCELLED
  SUSPENDED
}

enum MilestoneStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
  FUNDED
}

model LedgerCursor {
  id             String   @id @default(cuid())
  network        String   @unique
  lastLedgerSeq  Int      @map("last_ledger_seq")
  lastLedgerHash String?  @map("last_ledger_hash")
  updatedAt      DateTime @updatedAt @map("updated_at")
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("ledger_cursors")
}

model ProcessedEvent {
  id              String   @id @default(cuid())
  eventId         String   @unique @map("event_id")
  network         String
  ledgerSeq       Int      @map("ledger_seq")
  contractId      String   @map("contract_id")
  eventType       String   @map("event_type")
  transactionHash String   @map("transaction_hash")
  processedAt     DateTime @default(now()) @map("processed_at")

  @@index([network, ledgerSeq])
  @@index([contractId, eventType])
  @@map("processed_events")
}

model IndexerLog {
  id        String   @id @default(cuid())
  level     String
  message   String
  metadata  Json?
  timestamp DateTime @default(now())
  createdAt DateTime @default(now()) @map("created_at")

  @@index([timestamp])
  @@index([level])
  @@map("indexer_logs")
}

model NotificationSetting {
  id                  String   @id @default(cuid())
  userId              String   @unique @map("user_id")
  user                User     @relation(fields: [userId], references: [id])
  emailEnabled        Boolean  @default(true) @map("email_enabled")
  pushEnabled         Boolean  @default(false) @map("push_enabled")
  notifyContributions Boolean  @default(true) @map("notify_contributions")
  notifyMilestones    Boolean  @default(true) @map("notify_milestones")
  notifyDeadlines     Boolean  @default(true) @map("notify_deadlines")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@map("notification_settings")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String           @map("user_id")
  user      User             @relation(fields: [userId], references: [id])
  type      NotificationType
  title     String
  message   String
  read      Boolean          @default(false)
  data      Json? // Optional metadata (e.g., projectId)
  createdAt DateTime         @default(now()) @map("created_at")

  @@index([userId])
  @@map("notifications")
}

model EmailOutbox {
  id        String      @id @default(cuid())
  to        String
  subject   String
  html      String
  status    EmailStatus @default(PENDING)
  attempts  Int         @default(0)
  lastError String?     @map("last_error")
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  @@index([status])
  @@map("email_outbox")
}

enum NotificationType {
  CONTRIBUTION
  MILESTONE
  DEADLINE
  SYSTEM
}

enum EmailStatus {
  PENDING
  SENT
  FAILED
}

// Insurance Module Models

enum RiskType {
  PROJECT_FAILURE
  SMART_CONTRACT_EXPLOIT
  MARKET_VOLATILITY
}

enum ClaimStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
}

model InsurancePolicy {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  poolId         String   @map("pool_id")
  riskType       RiskType @map("risk_type")
  premium        Decimal  @map("premium")
  coverageAmount Decimal  @map("coverage_amount")
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("insurance_policies")
}

model InsurancePool {
  id            String   @id @default(cuid())
  name          String
  capital       Decimal  @default(0)
  lockedCapital Decimal  @default(0) @map("locked_capital")
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("insurance_pools")
}

model Claim {
  id           String      @id @default(cuid())
  policyId     String      @map("policy_id")
  claimAmount  Decimal     @map("claim_amount")
  status       ClaimStatus @default(PENDING)
  payoutAmount Decimal?    @map("payout_amount")
  createdAt    DateTime    @default(now()) @map("created_at")

  @@map("claims")
}

model ReinsuranceContract {
  id            String   @id @default(cuid())
  poolId        String   @map("pool_id")
  coverageLimit Decimal  @map("coverage_limit")
  premiumRate   Decimal  @map("premium_rate")
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("reinsurance_contracts")
}

// Privacy Analytics Models

model PrivacyBudget {
  id          String   @id @default(cuid())
  userId      String   @unique @map("user_id")
  totalBudget Float    @default(1.0) @map("total_budget")
  usedBudget  Float    @default(0.0) @map("used_budget")
  lastReset   DateTime @default(now()) @map("last_reset")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  queries PrivacyBudgetQuery[]

  @@map("privacy_budgets")
}

model PrivacyBudgetQuery {
  id          String        @id @default(cuid())
  budgetId    String        @map("budget_id")
  budget      PrivacyBudget @relation(fields: [budgetId], references: [id])
  queryId     String        @unique @map("query_id")
  epsilon     Float
  description String?
  status      QueryStatus   @default(COMPLETED)
  timestamp   DateTime      @default(now())
  createdAt   DateTime      @default(now()) @map("created_at")

  @@map("privacy_budget_queries")
}

model AnalyticsCache {
  id         String   @id @default(cuid())
  cacheKey   String   @unique @map("cache_key")
  queryType  String   @map("query_type")
  parameters Json // Query parameters
  result     Json // Differential privacy result
  epsilon    Float
  timestamp  DateTime @default(now())
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([cacheKey])
  @@index([expiresAt])
  @@map("analytics_cache")
}

enum QueryStatus {
  COMPLETED
  RESERVED
  FAILED
}

// ----------------------------------------------------
// Decentralized Reputation Oracle Models
// ----------------------------------------------------

enum ActivityType {
  SUCCESSFUL_TRANSACTION
  FAILED_TRANSACTION
  PEER_RATING
  COMMUNITY_REVIEW
  DISPUTE_WON
  DISPUTE_LOST
  HIGH_VALUE_CONTRIBUTION
}

model ReputationActivity {
  id           String       @id @default(cuid())
  subjectId    String       @map("subject_id")
  subject      User         @relation("ReputationSubject", fields: [subjectId], references: [id])
  actorId      String?      @map("actor_id")
  actor        User?        @relation("ReputationActor", fields: [actorId], references: [id])
  activityType ActivityType @map("activity_type")
  value        Float
  referenceId  String?      @map("reference_id")
  occurredAt   DateTime     @map("occurred_at")
  createdAt    DateTime     @default(now()) @map("created_at")

  @@index([subjectId])
  @@index([subjectId, activityType])
  @@index([occurredAt])
  @@map("reputation_activities")
}

model ReputationScore {
  id                     String   @id @default(cuid())
  subjectId              String   @unique @map("subject_id")
  subject                User     @relation(fields: [subjectId], references: [id])
  compositeScore         Float    @map("composite_score")
  successRateScore       Float    @map("success_rate_score")
  peerRatingScore        Float    @map("peer_rating_score")
  contributionSizeScore  Float    @map("contribution_size_score")
  communityFeedbackScore Float    @map("community_feedback_score")
  activityCount          Int      @map("activity_count")
  lowConfidence          Boolean  @default(false) @map("low_confidence")
  calculatedAt           DateTime @updatedAt @map("calculated_at")

  @@index([compositeScore])
  @@map("reputation_scores")
}

model ReputationEndorsement {
  id         String   @id @default(cuid())
  endorserId String   @map("endorser_id")
  endorser   User     @relation("Endorser", fields: [endorserId], references: [id])
  endorsedId String   @map("endorsed_id")
  endorsed   User     @relation("Endorsed", fields: [endorsedId], references: [id])
  weight     Float
  context    String?
  createdAt  DateTime @default(now()) @map("created_at")

  @@unique([endorserId, endorsedId])
  @@map("reputation_endorsements")
}

enum DisputeStatus {
  OPEN
  RESOLVED_IN_FAVOR
  RESOLVED_AGAINST
  DISMISSED
}

model ReputationDispute {
  id             String        @id @default(cuid())
  disputerId     String        @map("disputer_id")
  disputer       User          @relation("Disputer", fields: [disputerId], references: [id])
  disputedId     String        @map("disputed_id")
  disputed       User          @relation("Disputed", fields: [disputedId], references: [id])
  referenceId    String?       @map("reference_id")
  reason         String
  status         DisputeStatus @default(OPEN)
  resolutionNote String?       @map("resolution_note")
  createdAt      DateTime      @default(now()) @map("created_at")
  resolvedAt     DateTime?     @map("resolved_at")

  @@map("reputation_disputes")
}

model SybilProfile {
  id              String   @id @default(cuid())
  userId          String   @unique @map("user_id")
  user            User     @relation(fields: [userId], references: [id])
  riskScore       Float    @default(0.0) @map("risk_score")
  isFlagged       Boolean  @default(false) @map("is_flagged")
  heuristicsData  Json?    @map("heuristics_data")
  lastEvaluatedAt DateTime @updatedAt @map("last_evaluated_at")
  createdAt       DateTime @default(now()) @map("created_at")

  @@map("sybil_profiles")
}
