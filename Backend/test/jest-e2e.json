{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest",
  },
  "moduleNameMapping": {
    "^@/(.*)$": "<rootDir>/../src/$1",
    "^@cdp/(.*)$": "<rootDir>/../src/cdp/$1",
    "^@regulatory/(.*)$": "<rootDir>/../src/regulatory-reporting/$1"
  },
  "setupFilesAfterEnv": ["<rootDir>/jest.e2e-setup.ts"],
  "collectCoverageFrom": [
    "../src/**/*.(t|j)s",
    "!../src/**/*.d.ts",
    "!../src/main.ts",
    "!../src/**/*.spec.ts",
    "!../src/**/*.test.ts"
  ]
}
